# Expo inlines every EXPO_PUBLIC_* var into the client bundle at build time —
# never put a Supabase service-role key or any other server-only secret here
# (TEAM_CONTRACT §4.2). The anon key below is meant to be public.

# Base URL of the Express API (apps/api). Leave unset to run against the
# in-memory FixtureService demo instead of a real backend.
# EXPO_PUBLIC_API_URL=http://localhost:3001
# EXPO_PUBLIC_DEMO_MODE=true
# Demo mode is local-only and skips Supabase auth because the API itself is
# started with DEMO_MODE=true. Never enable it for a deployed API.

# Needed only when EXPO_PUBLIC_API_URL is set — used for anonymous sign-in so
# every install gets a real Supabase Auth user (no login screen exists yet;
# see apps/app/src/services/supabase-client.ts). Requires "Allow anonymous
# sign-ins" enabled in the Supabase project's Auth settings.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

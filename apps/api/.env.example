# Port the Express API listens on locally.
PORT=3001

# Leave SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY unset to run against the
# in-memory demo repos (default, no external services required — every
# request is attributed to a single fixed demo user, no auth needed).
#
# Set both to point at a real Supabase project (after running the
# migrations in apps/api/supabase/migrations/) to persist data for real
# and require a Supabase Auth bearer token on every /v1 request.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Overrides the automatic demo-mode detection above. Leave unset — only
# set this if you need to force one mode or the other explicitly.
# DEMO_MODE=true

# The fixed user id every request is attributed to in demo mode.
# DEMO_USER_ID=demo-user

# Port the Express API listens on locally.
PORT=3001

# The API refuses to start unless you pick one of the two modes below —
# there is no silent default (an accidental open, no-auth deployment is
# worse than a crash-on-boot with a clear error message).

# --- Local/demo mode ---
# Every request is attributed to one fixed user, no auth required, data
# lives in memory only (nothing persists across restarts). Never set this
# to true in a real deployment — the API also refuses to start with
# DEMO_MODE=true when NODE_ENV=production.
DEMO_MODE=true
# DEMO_USER_ID=demo-user

# --- Real mode ---
# Set both of these (and leave DEMO_MODE unset) to persist for real and
# require a Supabase Auth bearer token on every /v1 request. Run the
# migrations in apps/api/supabase/migrations/ first.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of origins allowed to call this API from a browser
# (Expo Web dev server ports by default).
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Caps on the in-memory repos (demo mode only) and on requests per user
# per window — all have sane defaults, override only if you need to.
# MEMORY_REPO_LIMIT=1000
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WRITE_MAX=20

# Fridge recognition sends each image to exactly one explicitly selected
# provider. Keep credentials server-side; never expose them to the app bundle.
# VISION_FEATURE_ENABLED=true
# VISION_PROVIDER=mimo
# MIMO_API_KEY=
# MIMO_VISION_MODEL=mimo-v2.5
# GEMINI_API_KEY=
# GEMINI_VISION_MODEL=gemini-3.5-flash-lite

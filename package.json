{
  "name": "akeso",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "app": "npm run start --workspace=apps/app",
    "app:web": "npm run web --workspace=apps/app",
    "api": "npm run dev --workspace=apps/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run apps/api"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
